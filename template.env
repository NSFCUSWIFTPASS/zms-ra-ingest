# Logging
RA_INGEST_LOG_LEVEL=INFO

# ZMS connection
RA_INGEST_ZMC_URL=http://zms-zmc-local-dev:8010/v1
RA_INGEST_TOKEN=your-zms-api-token

# RA facility identity in ZMS
RA_INGEST_ELEMENT_ID=00000000-0000-0000-0000-000000000000

# Spectrum - auto-created on startup if it doesn't exist
RA_INGEST_SPECTRUM_NAME=ATA L-band
RA_INGEST_SPECTRUM_MIN_FREQ_HZ=1000000000
RA_INGEST_SPECTRUM_MAX_FREQ_HZ=2000000000

# Poll behavior
RA_INGEST_POLL_INTERVAL_SECONDS=300

# Path to sources configuration
RA_INGEST_SOURCES_CONFIG=sources.json

# Daily email reports (optional)
RA_INGEST_REPORT_ENABLED=false
RA_INGEST_REPORT_CRON=0 8 * * *
RA_INGEST_SMTP_HOST=smtp.gmail.com
RA_INGEST_SMTP_PORT=587
RA_INGEST_SMTP_USER=
RA_INGEST_SMTP_PASSWORD=
RA_INGEST_REPORT_FROM=
RA_INGEST_REPORT_TO=
